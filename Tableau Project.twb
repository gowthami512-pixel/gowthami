  <worksheets>
    <worksheet name='Avg Profit by State '>
      <table>
        <view>
          <datasources>
            <datasource caption='Orders (Sales Data)' name='federated.03bsttj0ooqdv01dxgzha1ho7tjd' />
          </datasources>
          <datasource-dependencies datasource='federated.03bsttj0ooqdv01dxgzha1ho7tjd'>
            <column caption='Avg Profit Overall ' datatype='real' name='[Avg Sales Overall (copy)_1784551362850865155]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{FIXED:AVG(IF YEAR([Order Date])={MAX(YEAR([Order Date]))} THEN [Total CY Sales (copy)_1577104304697831427] END)}' />
            </column>
            <column caption='Avg Profit State Wise' datatype='real' name='[Avg Sales State Wise (copy)_1784551362851303428]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{FIXED [State/Province]:AVG([Total CY Sales (copy)_1577104304697831427])}' />
            </column>
            <column aggregation='Sum' datatype='real' name='[Column]' role='dimension' type='ordinal' />
            <column datatype='date' name='[Order Date]' role='dimension' type='ordinal' />
            <column datatype='real' name='[Profit]' role='measure' type='quantitative' />
            <column aggregation='Sum' datatype='integer' name='[Row]' role='dimension' type='ordinal' />
            <column caption='Profit Avg Color ' datatype='string' name='[Sales Avg Color (copy)_1784551362851688453]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [Avg Sales State Wise (copy)_1784551362851303428]&lt;[Avg Sales Overall (copy)_1784551362850865155] THEN &apos;Below Average&apos;&#13;&#10;ELSEIF [Avg Sales State Wise (copy)_1784551362851303428]&gt;[Avg Sales Overall (copy)_1784551362850865155] THEN &apos;Above Average&apos;&#13;&#10;ELSEIF [Avg Sales State Wise (copy)_1784551362851303428]=[Avg Sales Overall (copy)_1784551362850865155] THEN &apos;Equal Average&apos;&#13;&#10;END' />
            </column>
            <column datatype='string' name='[State/Province]' role='dimension' semantic-role='[State].[Name]' type='nominal' />
            <column caption='Total CY Profit' datatype='real' name='[Total CY Sales (copy)_1577104304697831427]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF YEAR([Order Date])={Max(YEAR([Order Date]))} THEN [Profit] END' />
            </column>
            <column-instance column='[State/Province]' derivation='Attribute' name='[attr:State/Province:nk]' pivot='key' type='nominal' />
            <column-instance column='[Column]' derivation='None' name='[none:Column:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Row]' derivation='None' name='[none:Row:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Sales Avg Color (copy)_1784551362851688453]' derivation='None' name='[none:Sales Avg Color (copy)_1784551362851688453:nk]' pivot='key' type='nominal' />
          </datasource-dependencies>
          <aggregation value='true' />
        </view>
